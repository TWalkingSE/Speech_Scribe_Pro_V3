# Speech Scribe Pro V3 - Configurações de Ambiente
# RENOMEIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES

# ===== HUGGING FACE TOKEN (OBRIGATÓRIO PARA DIARIZAÇÃO) =====
# Obtenha seu token em: https://huggingface.co/settings/tokens
# Necessário para usar modelos de diarização (separação de vozes)
# Aceite os termos do modelo em: https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=your_token_here

# ===== CONFIGURAÇÕES PADRÃO (OPCIONAL) =====
DEFAULT_MODEL=large-v2
DEFAULT_LANGUAGE=auto
DEFAULT_DEVICE=auto

# ===== CONFIGURAÇÕES DE GPU (OPCIONAL) =====
USE_GPU_PERCENT=90
CUDA_VISIBLE_DEVICES=0

# ===== CONFIGURAÇÕES DE DIARIZAÇÃO =====
ENABLE_DIARIZATION=false
DIARIZATION_DEVICE=auto

# ===== OUTRAS CONFIGURAÇÕES =====
LOG_LEVEL=INFO
MAX_WORKERS=4
