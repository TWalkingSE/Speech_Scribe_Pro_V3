# Speech Scribe Pro V3 - Configurações de Ambiente
# Renomeie este arquivo para .env e ajuste apenas o que for necessário.

# ===== OBRIGATÓRIO PARA DIARIZAÇÃO =====
# Obtenha seu token em: https://huggingface.co/settings/tokens
# Aceite os termos do modelo em: https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=

# ===== OVERRIDES OPCIONAIS DA APLICAÇÃO =====
# Valores válidos: auto, cpu, cuda
SPEECH_SCRIBE_DEVICE=auto

# Valores válidos: tiny, base, small, medium, large-v2, large-v3
SPEECH_SCRIBE_MODEL=small

# Exemplos: auto, pt, en, es, fr, de
SPEECH_SCRIBE_LANGUAGE=auto

# URL JSON para verificação de atualização da aplicação
SPEECH_SCRIBE_VERSION_URL=

# ===== OPCIONAL AVANÇADO =====
# Restringe as GPUs visíveis para CUDA/PyTorch antes do app carregar o torch.
# Exemplo: 0 ou 0,1
# CUDA_VISIBLE_DEVICES=
